// ============================================================
// QUANTUM TRADER PRO v4 — Full SMC Indicator
// Улучшения v4:
//   1. Фикс утечки labels (delete перед созданием новых)
//   2. Направленный RSI scoring (разный для LONG/SHORT)
//   3. BB Squeeze — направленный (учитывает close vs bb_mid)
//   4. Частичное закрытие TP1/TP2 с отображением в дашборде
//   5. Переворот сигнала при противоположном сигнале
//   6. Алерты alertcondition
//   7. VWAP в дашборде
//   8. EMA буфер как input параметр
//   9. FVG boxes — динамическое обновление правой границы
//  10. Защита R:R через nz + atr14
// ============================================================
//@version=5
indicator("Quantum Trader Pro v4", overlay=true, max_lines_count=300, max_labels_count=300, max_boxes_count=150)

// ─────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────
grp_sr   = "Support / Resistance"
grp_smc  = "SMC (FVG / OB)"
grp_sig  = "Signals"
grp_atr  = "ATR Levels"
grp_dash = "Dashboard"

pivot_lb  = input.int(10,    "Pivot Lookback",        group=grp_sr)
sr_touch  = input.int(2,     "Min Touches",           group=grp_sr)
fvg_atr_f = input.float(0.3, "FVG Min ATR Factor",    group=grp_smc)
ob_len    = input.int(3,     "OB Lookback (bars)",    group=grp_smc)
adx_len   = input.int(14,    "ADX Length",            group=grp_sig)
adx_min   = input.float(20,  "ADX Trend Threshold",   group=grp_sig)
vol_mult  = input.float(1.5, "Volume Spike Mult",     group=grp_sig)
ema_buf   = input.float(0.5, "EMA50 Buffer %",        group=grp_sig, minval=0.0, maxval=5.0, step=0.1)
atr_sl    = input.float(1.5, "SL × ATR",              group=grp_atr)
atr_tp1   = input.float(1.5, "TP1 × ATR",             group=grp_atr)
atr_tp2   = input.float(2.5, "TP2 × ATR",             group=grp_atr)
atr_tp3   = input.float(4.0, "TP3 × ATR",             group=grp_atr)
show_dash = input.bool(true,  "Show Dashboard",        group=grp_dash)
dash_pos  = input.string("Top Right", "Position",
             options=["Top Right","Top Left","Bottom Right","Bottom Left"], group=grp_dash)
txt_size  = input.string("Normal", "Text Size",
             options=["Tiny","Small","Normal","Large","Huge"], group=grp_dash)


// ─────────────────────────────────────────────────────────────
// БАЗОВЫЕ ИНДИКАТОРЫ
// ─────────────────────────────────────────────────────────────
atr14  = ta.atr(14)
ema50  = ta.ema(close, 50)
rsi14  = ta.rsi(close, 14)
vol_ma = ta.sma(volume, 20)

// ADX
[diplus, diminus, adx_val] = ta.dmi(adx_len, adx_len)

// Тренд с настраиваемым буфером
ema_buf_f  = ema_buf / 100.0
bull_trend = close > ema50 * (1 + ema_buf_f)
bear_trend = close < ema50 * (1 - ema_buf_f)
trend_dir  = bull_trend ? "BULL" : bear_trend ? "BEAR" : "NEUTRAL"

// BB
[bb_mid, bb_up, bb_dn] = ta.bb(close, 20, 2.0)
bb_w       = (bb_up - bb_dn) / bb_mid
bb_squeeze = bb_w < 0.04

// Volume spike
vol_spike = volume > vol_ma * vol_mult

// Режим рынка
adx_trending = adx_val > adx_min
mkt_mode     = adx_trending ? (diplus > diminus ? "TREND ▲" : "TREND ▼") : "RANGE"

// VWAP
vwap_val = ta.vwap(close)

// ─────────────────────────────────────────────────────────────
// FVG
// ─────────────────────────────────────────────────────────────
bull_fvg = low[0] > high[2] and (low[0] - high[2]) > atr14 * fvg_atr_f
bear_fvg = high[0] < low[2] and (low[2] - high[0]) > atr14 * fvg_atr_f

in_bull_fvg = bull_fvg[1] and close >= high[2] and close <= low[1]
in_bear_fvg = bear_fvg[1] and close <= low[2]  and close >= high[1]

// FVG boxes — храним ссылки для обновления правой границы
var box[] fvg_boxes = array.new_box()

if bull_fvg
    b = box.new(bar_index - 2, low, bar_index + 30, high[2],
         bgcolor=color.new(#00cc44, 88), border_color=color.new(#00cc44, 60))
    array.push(fvg_boxes, b)

if bear_fvg
    b = box.new(bar_index - 2, high, bar_index + 30, low[2],
         bgcolor=color.new(color.red, 88), border_color=color.new(color.red, 60))
    array.push(fvg_boxes, b)

// Обновляем правую границу активных боксов (не даём им "уходить в будущее")
if array.size(fvg_boxes) > 0
    for i = 0 to array.size(fvg_boxes) - 1
        b = array.get(fvg_boxes, i)
        if not na(b)
            box.set_right(b, bar_index + 5)
    // Чистим старые боксы (старше 100 баров)
    if array.size(fvg_boxes) > 50
        box.delete(array.shift(fvg_boxes))

// ─────────────────────────────────────────────────────────────
// ORDER BLOCKS
// ─────────────────────────────────────────────────────────────
bull_ob    = close[ob_len] < open[ob_len] and close > open and (close - open) > atr14 * 0.5
bear_ob    = close[ob_len] > open[ob_len] and close < open and (open - close) > atr14 * 0.5
in_bull_ob = bull_ob[1] and close >= low[ob_len+1]  and close <= high[ob_len+1]
in_bear_ob = bear_ob[1] and close <= high[ob_len+1] and close >= low[ob_len+1]

// ─────────────────────────────────────────────────────────────
// LIQUIDITY SWEEP
// ─────────────────────────────────────────────────────────────
swing_hi5  = ta.highest(high, 5)[1]
swing_lo5  = ta.lowest(low,   5)[1]
bull_sweep = low < swing_lo5 and close > swing_lo5 and vol_spike
bear_sweep = high > swing_hi5 and close < swing_hi5 and vol_spike

// ─────────────────────────────────────────────────────────────
// TRAP FILTER
// ─────────────────────────────────────────────────────────────
var int trap_cd = 0
trap_cd := trap_cd > 0 ? trap_cd - 1 : 0

ph = ta.pivothigh(high, 3, 3)
pl = ta.pivotlow(low,   3, 3)

// Используем close[4] т.к. pivothigh с offset=3 даёт значение 3 бара назад
bull_trap = not na(ph) and close[4] > ph and close[3] < ph and trap_cd == 0
bear_trap = not na(pl) and close[4] < pl and close[3] > pl and trap_cd == 0

if bull_trap or bear_trap
    trap_cd := 5


// ─────────────────────────────────────────────────────────────
// SCORING — направленный RSI и BB Squeeze
// ─────────────────────────────────────────────────────────────

// RSI: для LONG награждаем перепроданность/нейтраль (30-55)
//       для SHORT награждаем перекупленность/нейтраль (45-70)
rsi_long_score  = rsi14 >= 30 and rsi14 <= 55 ? 15 :
                  rsi14 >  55 and rsi14 <= 65 ? 7  : 0
rsi_short_score = rsi14 >= 45 and rsi14 <= 70 ? 15 :
                  rsi14 >= 35 and rsi14 <  45 ? 7  : 0

// ADX score (общий)
adx_score = adx_val > 25 ? 10 : adx_val > 20 ? 7 : 0

// BB Squeeze — направленный: close выше mid = бычий пробой, ниже = медвежий
bb_long_score  = bb_squeeze and close > bb_mid ? 10 : 0
bb_short_score = bb_squeeze and close < bb_mid ? 10 : 0

score_long  = (bull_trend   ? 25 : 0)
             + (in_bull_fvg  ? 12 : 0)
             + (in_bull_ob   ?  8 : 0)
             + rsi_long_score
             + adx_score
             + (vol_spike    ? 10 : 0)
             + bb_long_score
             + (bull_sweep   ? 10 : 0)

score_short = (bear_trend   ? 25 : 0)
             + (in_bear_fvg  ? 12 : 0)
             + (in_bear_ob   ?  8 : 0)
             + rsi_short_score
             + adx_score
             + (vol_spike    ? 10 : 0)
             + bb_short_score
             + (bear_sweep   ? 10 : 0)

sig_min   = 65
long_sig  = score_long  >= sig_min and bull_trend and not bull_trap and rsi14 < 75
short_sig = score_short >= sig_min and bear_trend and not bear_trap and rsi14 > 25

// ─────────────────────────────────────────────────────────────
// УПРАВЛЕНИЕ СИГНАЛОМ
// ─────────────────────────────────────────────────────────────
var float  sig_entry  = na
var float  sig_sl     = na
var float  sig_tp1    = na
var float  sig_tp2    = na
var float  sig_tp3    = na
var string sig_dir    = na
var int    sig_score  = 0
var bool   sig_active = false
var int    tp_hits    = 0   // 0=none, 1=TP1 hit, 2=TP2 hit

// Открытие нового сигнала
if long_sig and not sig_active
    sig_entry  := close
    sig_sl     := close - atr14 * atr_sl
    sig_tp1    := close + atr14 * atr_tp1
    sig_tp2    := close + atr14 * atr_tp2
    sig_tp3    := close + atr14 * atr_tp3
    sig_dir    := "LONG"
    sig_score  := score_long
    sig_active := true
    tp_hits    := 0

if short_sig and not sig_active
    sig_entry  := close
    sig_sl     := close + atr14 * atr_sl
    sig_tp1    := close - atr14 * atr_tp1
    sig_tp2    := close - atr14 * atr_tp2
    sig_tp3    := close - atr14 * atr_tp3
    sig_dir    := "SHORT"
    sig_score  := score_short
    sig_active := true
    tp_hits    := 0

// Отслеживание частичных TP
if sig_active
    if sig_dir == "LONG"
        if high >= sig_tp1 and tp_hits == 0
            tp_hits := 1
        if high >= sig_tp2 and tp_hits == 1
            tp_hits := 2
    else
        if low <= sig_tp1 and tp_hits == 0
            tp_hits := 1
        if low <= sig_tp2 and tp_hits == 1
            tp_hits := 2

// Деактивация: SL, TP3 или переворот
if sig_active
    hit_sl      = sig_dir == "LONG"  ? low  <= sig_sl  : high >= sig_sl
    hit_tp3     = sig_dir == "LONG"  ? high >= sig_tp3 : low  <= sig_tp3
    // Переворот — противоположный сигнал закрывает текущий
    reversal    = (sig_dir == "LONG" and short_sig) or (sig_dir == "SHORT" and long_sig)

    if hit_sl or hit_tp3 or reversal
        sig_active := false
        sig_entry  := na
        sig_sl     := na
        sig_tp1    := na
        sig_tp2    := na
        sig_tp3    := na
        tp_hits    := 0


// ─────────────────────────────────────────────────────────────
// РИСУЕМ УРОВНИ (линии — только при активном сигнале)
// ─────────────────────────────────────────────────────────────
plot(sig_active ? sig_entry : na, "Entry",  color=color.white,  linewidth=1, style=plot.style_linebr)
plot(sig_active ? sig_sl    : na, "SL",     color=color.red,    linewidth=2, style=plot.style_linebr)
plot(sig_active ? sig_tp1   : na, "TP1",    color=color.yellow, linewidth=1, style=plot.style_linebr)
plot(sig_active ? sig_tp2   : na, "TP2",    color=#00cc44,      linewidth=2, style=plot.style_linebr)
plot(sig_active ? sig_tp3   : na, "TP3",    color=#00ffcc,      linewidth=1, style=plot.style_linebr)

// ─────────────────────────────────────────────────────────────
// LABELS УРОВНЕЙ — создаём ТОЛЬКО на баре входа, удаляем старые
// ─────────────────────────────────────────────────────────────
var label lbl_tp3   = na
var label lbl_tp2   = na
var label lbl_tp1   = na
var label lbl_entry = na
var label lbl_sl    = na

// Новый сигнал = только что активировался (предыдущий бар не был активен)
new_signal = sig_active and not sig_active[1]

if new_signal
    // Удаляем предыдущие labels уровней
    label.delete(lbl_tp3)
    label.delete(lbl_tp2)
    label.delete(lbl_tp1)
    label.delete(lbl_entry)
    label.delete(lbl_sl)

    rr_val  = math.abs(sig_tp2 - sig_entry) / math.max(nz(math.abs(sig_entry - sig_sl), atr14), 0.001)
    rr_str  = "R:R 1:" + str.tostring(math.round(rr_val, 1))
    clr_dir = sig_dir == "LONG" ? color.new(#00cc44, 0) : color.new(color.red, 0)

    lbl_tp3   := label.new(bar_index, sig_tp3,
                  "TP3  " + str.tostring(math.round(sig_tp3, 2)),
                  style=label.style_label_left, color=color.new(#00ffcc, 80),
                  textcolor=color.white, size=size.normal)

    lbl_tp2   := label.new(bar_index, sig_tp2,
                  "TP2  " + str.tostring(math.round(sig_tp2, 2)) + "  " + rr_str,
                  style=label.style_label_left, color=color.new(#00cc44, 70),
                  textcolor=color.white, size=size.normal)

    lbl_tp1   := label.new(bar_index, sig_tp1,
                  "TP1  " + str.tostring(math.round(sig_tp1, 2)),
                  style=label.style_label_left, color=color.new(color.yellow, 70),
                  textcolor=color.black, size=size.normal)

    lbl_entry := label.new(bar_index, sig_entry,
                  "ENTRY  " + str.tostring(math.round(sig_entry, 2)) + "  [" + sig_dir + "]",
                  style=label.style_label_left, color=clr_dir,
                  textcolor=color.white, size=size.large)

    lbl_sl    := label.new(bar_index, sig_sl,
                  "SL  " + str.tostring(math.round(sig_sl, 2)),
                  style=label.style_label_left, color=color.new(color.red, 60),
                  textcolor=color.white, size=size.normal)

// ─────────────────────────────────────────────────────────────
// СИГНАЛЬНЫЕ МЕТКИ НА БАРЕ (только на баре сигнала)
// ─────────────────────────────────────────────────────────────
if long_sig
    label.new(bar_index, low - atr14 * 0.5,
              "▲ LONG\n" + str.tostring(score_long),
              color=color.new(#00cc44, 10), textcolor=color.white,
              style=label.style_label_up, size=size.normal)

if short_sig
    label.new(bar_index, high + atr14 * 0.5,
              "▼ SHORT\n" + str.tostring(score_short),
              color=color.new(color.red, 10), textcolor=color.white,
              style=label.style_label_down, size=size.normal)

if bull_trap
    label.new(bar_index, high + atr14,
              "BULL\nTRAP", color=color.orange, textcolor=color.black,
              style=label.style_label_down, size=size.small)

if bear_trap
    label.new(bar_index, low - atr14,
              "BEAR\nTRAP", color=color.orange, textcolor=color.black,
              style=label.style_label_up, size=size.small)

// ─────────────────────────────────────────────────────────────
// SWEEP МАРКЕРЫ
// ─────────────────────────────────────────────────────────────
plotshape(bull_sweep, title="Bull Sweep", location=location.belowbar,
          style=shape.diamond, color=color.new(#00ffcc, 0), size=size.small)
plotshape(bear_sweep, title="Bear Sweep", location=location.abovebar,
          style=shape.diamond, color=color.new(color.orange, 0), size=size.small)

// ─────────────────────────────────────────────────────────────
// VWAP + EMA50
// ─────────────────────────────────────────────────────────────
plot(vwap_val, "VWAP",  color=color.new(color.purple, 30), linewidth=1)
plot(ema50,    "EMA50", color=color.new(color.blue,   40), linewidth=1)

// ─────────────────────────────────────────────────────────────
// АЛЕРТЫ
// ─────────────────────────────────────────────────────────────
alertcondition(long_sig,   "LONG Signal",  "Quantum v4: LONG на {{ticker}}")
alertcondition(short_sig,  "SHORT Signal", "Quantum v4: SHORT на {{ticker}}")
alertcondition(bull_trap,  "Bull Trap",    "Quantum v4: BULL TRAP на {{ticker}}")
alertcondition(bear_trap,  "Bear Trap",    "Quantum v4: BEAR TRAP на {{ticker}}")
alertcondition(bull_sweep, "Bull Sweep",   "Quantum v4: Liquidity Sweep BULL на {{ticker}}")
alertcondition(bear_sweep, "Bear Sweep",   "Quantum v4: Liquidity Sweep BEAR на {{ticker}}")


// ─────────────────────────────────────────────────────────────
// DASHBOARD
// ─────────────────────────────────────────────────────────────
// Таблица создаётся вне if show_dash чтобы корректно скрываться
var table dash = table.new(
     dash_pos == "Top Right"    ? position.top_right    :
     dash_pos == "Top Left"     ? position.top_left     :
     dash_pos == "Bottom Right" ? position.bottom_right :
     position.bottom_left,
     2, 16,
     bgcolor=color.new(#0d1117, 5),
     border_color=color.new(#30363d, 80),
     border_width=1,
     frame_color=color.new(#58a6ff, 60),
     frame_width=2)

if show_dash
    txt = txt_size == "Tiny"   ? size.tiny   :
          txt_size == "Small"  ? size.small  :
          txt_size == "Normal" ? size.normal :
          txt_size == "Large"  ? size.large  : size.huge

    // Цвета
    c_title = color.new(#58a6ff, 0)
    c_bull  = color.new(#00cc44, 0)
    c_bear  = color.new(#ff4444, 0)
    c_neut  = color.new(#cccccc, 0)
    c_warn  = color.new(#ffaa00, 0)
    c_val   = color.new(#e6edf3, 0)
    c_head  = color.new(#0d1117, 0)
    c_bg_h  = color.new(#161b22, 0)

    trend_c = bull_trend ? c_bull : bear_trend ? c_bear : c_neut
    mkt_c   = adx_trending ? (diplus > diminus ? c_bull : c_bear) : c_warn
    sig_clr = sig_active ? (sig_dir == "LONG" ? c_bull : c_bear) : c_neut

    // TP статус для дашборда
    tp_status   = not sig_active ? "—" : tp_hits == 2 ? "TP1 + TP2 hit" : tp_hits == 1 ? "TP1 hit" : "waiting"
    tp_status_c = tp_hits >= 2 ? c_bull : tp_hits == 1 ? c_warn : c_neut

    // R:R
    rr_display = sig_active ?
                 "1:" + str.tostring(math.round(
                     math.abs(sig_tp2 - sig_entry) /
                     math.max(nz(math.abs(sig_entry - sig_sl), atr14), 0.001), 1)) : "—"

    // VWAP позиция
    vwap_pos   = close > vwap_val ? "Above ▲" : "Below ▼"
    vwap_pos_c = close > vwap_val ? c_bull : c_bear

    // Row 0 — Заголовок
    table.cell(dash, 0, 0, "⚡ QUANTUM TRADER PRO",
               text_color=c_title, text_size=txt, bgcolor=c_bg_h, text_halign=text.align_center)
    table.cell(dash, 1, 0, "v4.0",
               text_color=c_neut, text_size=size.small, bgcolor=c_bg_h, text_halign=text.align_center)

    // Row 1 — Market Mode
    table.cell(dash, 0, 1, "Market Mode", text_color=c_neut, text_size=txt, bgcolor=c_head)
    table.cell(dash, 1, 1, mkt_mode,      text_color=mkt_c,  text_size=txt, bgcolor=c_head)

    // Row 2 — Trend EMA50
    table.cell(dash, 0, 2, "Trend EMA50", text_color=c_neut,   text_size=txt, bgcolor=c_bg_h)
    table.cell(dash, 1, 2, trend_dir,     text_color=trend_c,  text_size=txt, bgcolor=c_bg_h)

    // Row 3 — ADX
    table.cell(dash, 0, 3, "ADX", text_color=c_neut, text_size=txt, bgcolor=c_head)
    table.cell(dash, 1, 3, str.tostring(math.round(adx_val, 1)),
               text_color=adx_val > 25 ? c_bull : adx_val > 15 ? c_warn : c_bear,
               text_size=txt, bgcolor=c_head)

    // Row 4 — RSI
    table.cell(dash, 0, 4, "RSI(14)", text_color=c_neut, text_size=txt, bgcolor=c_bg_h)
    table.cell(dash, 1, 4, str.tostring(math.round(rsi14, 1)),
               text_color=rsi14 > 70 ? c_bear : rsi14 < 30 ? c_bull : c_val,
               text_size=txt, bgcolor=c_bg_h)

    // Row 5 — ATR
    table.cell(dash, 0, 5, "ATR(14)", text_color=c_neut, text_size=txt, bgcolor=c_head)
    table.cell(dash, 1, 5, str.tostring(math.round(atr14, 4)),
               text_color=c_val, text_size=txt, bgcolor=c_head)

    // Row 6 — VWAP
    table.cell(dash, 0, 6, "VWAP", text_color=c_neut,    text_size=txt, bgcolor=c_bg_h)
    table.cell(dash, 1, 6, vwap_pos, text_color=vwap_pos_c, text_size=txt, bgcolor=c_bg_h)

    // Row 7 — Volume Spike
    table.cell(dash, 0, 7, "Volume Spike", text_color=c_neut, text_size=txt, bgcolor=c_head)
    table.cell(dash, 1, 7, vol_spike ? "YES ▲" : "no",
               text_color=vol_spike ? c_bull : c_neut, text_size=txt, bgcolor=c_head)

    // Row 8 — BB Squeeze
    table.cell(dash, 0, 8, "BB Squeeze", text_color=c_neut, text_size=txt, bgcolor=c_bg_h)
    table.cell(dash, 1, 8, bb_squeeze ? "SQUEEZE!" : "normal",
               text_color=bb_squeeze ? c_warn : c_neut, text_size=txt, bgcolor=c_bg_h)

    // Row 9 — Sweep
    table.cell(dash, 0, 9, "Sweep", text_color=c_neut, text_size=txt, bgcolor=c_head)
    table.cell(dash, 1, 9, bull_sweep ? "BULL ▲" : bear_sweep ? "BEAR ▼" : "—",
               text_color=bull_sweep ? c_bull : bear_sweep ? c_bear : c_neut,
               text_size=txt, bgcolor=c_head)

    // Row 10 — Trap Filter
    table.cell(dash, 0, 10, "Trap Filter", text_color=c_neut, text_size=txt, bgcolor=c_bg_h)
    table.cell(dash, 1, 10, bull_trap ? "BULL TRAP" : bear_trap ? "BEAR TRAP" : "clear",
               text_color=bull_trap or bear_trap ? c_warn : c_bull,
               text_size=txt, bgcolor=c_bg_h)

    // Row 11 — Разделитель
    table.cell(dash, 0, 11, "──── SIGNAL ────",
               text_color=c_title, text_size=txt, bgcolor=c_bg_h, text_halign=text.align_center)
    table.cell(dash, 1, 11, "──────────────",
               text_color=c_title, text_size=txt, bgcolor=c_bg_h, text_halign=text.align_center)

    // Row 12 — Direction
    table.cell(dash, 0, 12, "Direction", text_color=c_neut, text_size=txt, bgcolor=c_head)
    table.cell(dash, 1, 12, sig_active ? sig_dir : "—",
               text_color=sig_clr, text_size=txt, bgcolor=c_head)

    // Row 13 — Score
    table.cell(dash, 0, 13, "Score", text_color=c_neut, text_size=txt, bgcolor=c_bg_h)
    table.cell(dash, 1, 13, sig_active ? str.tostring(sig_score) + "/100" : "—",
               text_color=sig_active and sig_score >= 80 ? c_bull :
                           sig_active and sig_score >= 65 ? c_warn : c_neut,
               text_size=txt, bgcolor=c_bg_h)

    // Row 14 — R:R
    table.cell(dash, 0, 14, "R:R (TP2)", text_color=c_neut, text_size=txt, bgcolor=c_head)
    table.cell(dash, 1, 14, rr_display,
               text_color=sig_active ? c_bull : c_neut, text_size=txt, bgcolor=c_head)

    // Row 15 — TP Status
    table.cell(dash, 0, 15, "TP Status", text_color=c_neut,     text_size=txt, bgcolor=c_bg_h)
    table.cell(dash, 1, 15, tp_status,   text_color=tp_status_c, text_size=txt, bgcolor=c_bg_h)
